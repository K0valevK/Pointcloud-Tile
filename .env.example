# =============================================================================
# Pointcloud-Tile — переменные окружения
# Скопируйте в .env и измените при необходимости
# =============================================================================

# Общие
APP_NAME=Pointcloud-Tile
DEBUG=false
LOG_LEVEL=INFO

# HTTP API
HOST=0.0.0.0
PORT=8000
TMS_VERSION=1.0.0
DEFAULT_TILE_FORMAT=laz

# Тайлирование
TILE_SIZE_M=100
LOD_LEVELS=5
MAX_TILE_SIZE_MB=5

# Хранилище: filesystem | s3
STORAGE_BACKEND=filesystem
TILES_DIR=/data/tiles
LAYERS_DIR=/data/layers
CHECKPOINT_DIR=/data/checkpoints

# MinIO / S3 (при STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pointcloud-tiles
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true
